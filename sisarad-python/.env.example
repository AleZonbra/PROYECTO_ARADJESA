# Copia este archivo como ".env" en sisarad-python (ya incluido si se generó automáticamente).

SISARAD_APP_URL=http://127.0.0.1:8000

# local = bandeja en /bandeja-correo (recomendado para desarrollo)
# smtp = envío real por correo
# auto = SMTP si está completo, si no bandeja local
SISARAD_EMAIL_MODE=local

# Solo si SISARAD_EMAIL_MODE=smtp
# SISARAD_SMTP_HOST=smtp.gmail.com
# SISARAD_SMTP_PORT=587
# SISARAD_SMTP_USER=tu_correo@gmail.com
# SISARAD_SMTP_PASSWORD=contraseña_de_aplicacion
# SISARAD_SMTP_FROM=SISARAD <tu_correo@gmail.com>
# SISARAD_SMTP_TLS=true

SISARAD_RESET_EXPIRE_MINUTES=60
SISARAD_RESET_CODE_LENGTH=6
